{
  "name": "previewer",
  "version": "0.0.0",
  "private": true,
  "description": "Desktop app for reviewing diffs with persistent review state and LSP-aware reading.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sylophi/PReviewer.git"
  },
  "main": ".vite/build/index.js",
  "scripts": {
    "start": "electron-forge start",
    "dev": "pnpm run start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "typecheck": "tsc --noEmit",
    "verify:git": "pnpm dlx tsx scripts/verify-git-layer.ts",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "icon": "uv run scripts/build-app-icon.py",
    "postinstall": "node scripts/copy-material-icons.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@monaco-editor/react": "^4.6.0",
    "@pierre/theme": "^1.0.3",
    "@shikijs/monaco": "^4.1.0",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-router": "1.169.2",
    "@tanstack/react-virtual": "^3.13.24",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.577.0",
    "material-icon-theme": "^5.34.0",
    "monaco-editor": "^0.52.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.1",
    "shiki": "^4.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron-forge/publisher-github": "7.11.1",
    "@electron-forge/shared-types": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^22.13.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "dotenv": "^17.4.2",
    "electron": "42.0.0",
    "lefthook": "^2.1.4",
    "oxfmt": "0.48.0",
    "oxlint": "1.63.0",
    "react-grab": "^0.1.33",
    "tailwindcss": "^4.2.1",
    "typescript": "~7.0.2",
    "vite": "^8.0.0"
  },
  "packageManager": "pnpm@11.1.1",
  "productName": "PReviewer"
}
